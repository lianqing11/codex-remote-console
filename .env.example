# Example environment for Codex Remote Console.
# Export these variables in your shell or process manager before starting the server.

PORT=3027
HOST=0.0.0.0

# Set one of these for private deployments. Production requires one of them.
# CODEX_WEB_PASSWORD=replace-with-strong-password
# CODEX_WEB_TOKEN=replace-with-random-token

# Use a separate random cookie-signing secret for production.
# CODEX_WEB_SECRET=replace-with-random-secret

# Set when serving behind a subpath reverse proxy, for example /codex_web.
# NEXT_PUBLIC_BASE_PATH=/codex_web

# Optional project roots for the directory picker. Separate entries with ":" on Unix and ";" on Windows.
# CODEX_WEB_PROJECT_ROOTS=/absolute/path/to/projects

# Optional behavior switches.
# CODEX_WEB_GATEWAY=stdio
# CODEX_WEB_AUTO_APPROVE=on
# CODEX_WEB_AUTO_APPROVE_READONLY=on
# CODEX_WEB_AUTO_APPROVE_MCP=on
# CODEX_WEB_APPROVAL_LOG=on
